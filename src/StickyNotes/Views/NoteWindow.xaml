<Window x:Class="StickyNotes.Views.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:StickyNotes.Converters"
        Title="StickyNote"
        Height="260" Width="260"
        MinHeight="100" MinWidth="180"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        RenderOptions.ClearTypeHint="Enabled"
        TextElement.FontFamily="LXGW WenKai, Segoe UI Variable, Segoe UI"
        TextElement.FontSize="16">

    <Window.ContextMenu>
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="锁定/解锁" Command="{Binding ToggleLockCommand}" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid>
    <Border x:Name="GlassBorder"
            CornerRadius="12"
            Background="#01FFFFFF"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            PreviewMouseLeftButtonDown="TopBar_PreviewMouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: all function buttons (no title text) -->
            <Grid Grid.Row="0"
                  Height="34"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Drag handle (invisible, fills left side) -->

                <!-- All buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Style="{StaticResource AutoHideElement}">
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="+" Command="{Binding NewNoteCommand}"
                            ToolTip="新建便签" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="🎨" Command="{Binding CycleColorCommand}"
                            ToolTip="切换颜色" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="☑" Click="TodoToggle_Click"
                            ToolTip="切换待办 (Ctrl+D)" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="A"
                            Foreground="{Binding ForegroundBrush}"
                            Command="{Binding CycleFontColorCommand}"
                            FontSize="11" ToolTip="字体颜色" />
                    <!-- Font size: button toggles popup slider -->
                    <Button x:Name="FontSizeBtn"
                            Style="{StaticResource NoteToolbarButton}"
                            Content="Aˢ"
                            FontSize="10" ToolTip="字体大小"
                            Click="FontSizeBtn_Click" />
                    <!-- Line spacing: button toggles popup slider -->
                    <Button x:Name="LineSpacingBtn"
                            Style="{StaticResource NoteToolbarButton}"
                            Content="↕ˢ"
                            FontSize="10" ToolTip="行间距"
                            Click="LineSpacingBtn_Click" />
                    <!-- Clear completed todos -->
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="🗑"
                            FontSize="11" ToolTip="清除已完成"
                            Click="ClearCompleted_Click" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="🔒" Command="{Binding ToggleLockCommand}"
                            ToolTip="锁定便签" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="✕" Command="{Binding DeleteCommand}"
                            ToolTip="删除便签" />
                </StackPanel>

                <!-- Unlock button (locked mode) -->
                <Button Grid.Column="1"
                        Content="🔓"
                        Style="{StaticResource LockedUnlockButton}"
                        Command="{Binding ToggleLockCommand}"
                        ToolTip="解锁便签"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="1"
                       Height="1"
                       Margin="12,0,12,0"
                       Fill="{StaticResource NoteSeparatorBrush}"
                       Style="{StaticResource AutoHideElement}" />

            <!-- Content -->
            <TextBox x:Name="ContentBox"
                     Grid.Row="2"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="{Binding ForegroundBrush}"
                     FontSize="{Binding FontSize}"
                     Margin="6,2,6,4"
                     IsReadOnly="{Binding IsLocked}"
                     PreviewKeyDown="ContentBox_PreviewKeyDown"
                     PreviewMouseLeftButtonDown="ContentBox_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="ContentBox_PreviewMouseMove">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource NoteBodyTextBox}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter Property="ContextMenu" Value="{x:Null}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Footer: opacity slider only -->
            <Grid Grid.Row="3"
                  Height="34"
                  Margin="10,0,10,6"
                  Style="{StaticResource AutoHideElement}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="◐"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{Binding ForegroundBrush}"
                           Opacity="0.45"
                           Margin="0,0,8,0" />

                <Slider Grid.Column="1"
                        Value="{Binding Opacity}"
                        Minimum="0.1" Maximum="1.0"
                        VerticalAlignment="Center"
                        Style="{StaticResource GlassSlider}" />
            </Grid>
        </Grid>
    </Border>

    <!-- Font size popup -->
    <Popup x:Name="FontSizePopup"
           PlacementTarget="{Binding ElementName=FontSizeBtn}"
           Placement="Bottom" StaysOpen="True"
           AllowsTransparency="True" PopupAnimation="Fade">
        <Border Background="#E02D2D30" CornerRadius="8" Padding="6,4" BorderThickness="0"
                MouseLeave="PopupContent_MouseLeave">
            <StackPanel Width="120">
                <TextBlock Text="{Binding FontSize, StringFormat='字体: {0:F0}px'}"
                           Foreground="White" FontSize="11" Margin="0,0,0,4" />
                <Slider Value="{Binding FontSize}" Minimum="10" Maximum="36"
                        Style="{StaticResource GlassSlider}" />
            </StackPanel>
        </Border>
    </Popup>

    <!-- Line spacing popup -->
    <Popup x:Name="LineSpacingPopup"
           PlacementTarget="{Binding ElementName=LineSpacingBtn}"
           Placement="Bottom" StaysOpen="True"
           AllowsTransparency="True" PopupAnimation="Fade">
        <Border Background="#E02D2D30" CornerRadius="8" Padding="6,4" BorderThickness="0"
                MouseLeave="PopupContent_MouseLeave">
            <StackPanel Width="120">
                <TextBlock Text="{Binding LineSpacing, StringFormat='行距: {0:F2}x'}"
                           Foreground="White" FontSize="11" Margin="0,0,0,4" />
                <Slider Value="{Binding LineSpacing}" Minimum="1.0" Maximum="2.5"
                        Style="{StaticResource GlassSlider}" />
            </StackPanel>
        </Border>
    </Popup>
    </Grid>
</Window>
