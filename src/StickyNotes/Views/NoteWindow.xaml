<Window x:Class="StickyNotes.Views.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:StickyNotes.Converters"
        Title="StickyNote"
        Height="260" Width="260"
        MinHeight="120" MinWidth="180"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        RenderOptions.ClearTypeHint="Enabled"
        TextElement.FontFamily="LXGW WenKai, Segoe UI Variable, Segoe UI"
        TextElement.FontSize="16">

    <!-- Right-click context menu (for unlocking when controls are hidden) -->
    <Window.ContextMenu>
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="锁定/解锁" Command="{Binding ToggleLockCommand}" />
        </ContextMenu>
    </Window.ContextMenu>

    <!-- Glass card: frosted background with subtle border -->
    <Border x:Name="GlassBorder"
            CornerRadius="12"
            Background="#01FFFFFF"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar with toolbar -->
            <Grid Grid.Row="0"
                  Height="36"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{Binding ForegroundBrush}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         Margin="6,0,0,0"
                         IsReadOnly="{Binding IsLocked}"
                         ToolTip="便签标题">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource NoteTitleTextBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                    <Setter Property="ContextMenu" Value="{x:Null}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Toolbar (visible on hover, hidden when locked) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Style="{StaticResource AutoHideElement}">
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="+"
                            Command="{Binding NewNoteCommand}"
                            ToolTip="新建便签" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="🎨"
                            Command="{Binding CycleColorCommand}"
                            ToolTip="切换颜色" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="A"
                            Foreground="{Binding ForegroundBrush}"
                            Command="{Binding CycleFontColorCommand}"
                            FontSize="12"
                            ToolTip="切换字体颜色" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="A⁺"
                            Command="{Binding IncreaseFontCommand}"
                            FontSize="11"
                            ToolTip="放大字体" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="A⁻"
                            Command="{Binding DecreaseFontCommand}"
                            FontSize="11"
                            ToolTip="缩小字体" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="↕⁺"
                            Command="{Binding IncreaseLineSpacingCommand}"
                            FontSize="11"
                            ToolTip="增加行间距" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="↕⁻"
                            Command="{Binding DecreaseLineSpacingCommand}"
                            FontSize="11"
                            ToolTip="减少行间距" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="☑"
                            Click="TodoToggle_Click"
                            ToolTip="切换待办 (Ctrl+D)" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="🔒"
                            Command="{Binding ToggleLockCommand}"
                            ToolTip="锁定便签" />
                    <Button Style="{StaticResource NoteToolbarButton}"
                            Content="✕"
                            Command="{Binding DeleteCommand}"
                            ToolTip="删除便签" />
                </StackPanel>

                <!-- Unlock button (visible on hover when locked) -->
                <Button Grid.Column="1"
                        Content="🔓"
                        Style="{StaticResource LockedUnlockButton}"
                        Command="{Binding ToggleLockCommand}"
                        ToolTip="解锁便签"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />
            </Grid>

            <!-- Separator line (hidden when locked) -->
            <Rectangle Grid.Row="1"
                       Height="1"
                       Margin="12,0,12,0"
                       Fill="{StaticResource NoteSeparatorBrush}"
                       Style="{StaticResource AutoHideElement}" />

            <!-- Content TextBox: ☐/☑ glyphs via converter, click to toggle -->
            <TextBox x:Name="ContentBox"
                     Grid.Row="2"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="{Binding ForegroundBrush}"
                     FontSize="{Binding FontSize}"
                     Margin="4,2,4,2"
                     IsReadOnly="{Binding IsLocked}"
                     PreviewKeyDown="ContentBox_PreviewKeyDown"
                     PreviewMouseLeftButtonDown="ContentBox_PreviewMouseLeftButtonDown"
                     ToolTip="便签内容&#x0a;点击 ☐/☑ 或 Ctrl+D 切换待办状态">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource NoteBodyTextBox}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter Property="ContextMenu" Value="{x:Null}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Footer with opacity slider -->
            <Grid Grid.Row="3"
                  Margin="12,2,12,8"
                  Style="{StaticResource AutoHideElement}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="◐"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{Binding ForegroundBrush}"
                           Opacity="0.45"
                           Margin="0,0,8,0" />

                <Slider Grid.Column="1"
                        Value="{Binding Opacity}"
                        Minimum="0.1" Maximum="1.0"
                        VerticalAlignment="Center"
                        ToolTip="调整透明度"
                        Style="{StaticResource GlassSlider}" />
            </Grid>
        </Grid>
    </Border>
</Window>
