<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Note color palettes ===== -->
    <Color x:Key="NoteYellowColor">#FFFFF9C4</Color>
    <Color x:Key="NotePinkColor">#FFFFCDD2</Color>
    <Color x:Key="NoteGreenColor">#FFC8E6C9</Color>
    <Color x:Key="NoteBlueColor">#FFBBDEFB</Color>
    <Color x:Key="NotePurpleColor">#FFE1BEE7</Color>
    <Color x:Key="NoteOrangeColor">#FFFFE0B2</Color>
    <Color x:Key="NoteWhiteColor">#FFFFFFFF</Color>
    <Color x:Key="NoteDarkColor">#FF2D2D30</Color>

    <!-- ===== Note backgrounds ===== -->
    <SolidColorBrush x:Key="NoteYellowBrush" Color="#FFFFF9C4" />
    <SolidColorBrush x:Key="NotePinkBrush" Color="#FFFFCDD2" />
    <SolidColorBrush x:Key="NoteGreenBrush" Color="#FFC8E6C9" />
    <SolidColorBrush x:Key="NoteBlueBrush" Color="#FFBBDEFB" />
    <SolidColorBrush x:Key="NotePurpleBrush" Color="#FFE1BEE7" />
    <SolidColorBrush x:Key="NoteOrangeBrush" Color="#FFFFE0B2" />
    <SolidColorBrush x:Key="NoteWhiteBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="NoteDarkBrush" Color="#FF2D2D30" />

    <!-- ===== Foreground text brushes ===== -->
    <SolidColorBrush x:Key="NoteYellowForeground" Color="#FF5D4037" />
    <SolidColorBrush x:Key="NotePinkForeground" Color="#FF5D4037" />
    <SolidColorBrush x:Key="NoteGreenForeground" Color="#FF1B5E20" />
    <SolidColorBrush x:Key="NoteBlueForeground" Color="#FF0D47A1" />
    <SolidColorBrush x:Key="NotePurpleForeground" Color="#FF4A148C" />
    <SolidColorBrush x:Key="NoteOrangeForeground" Color="#FF5D4037" />
    <SolidColorBrush x:Key="NoteWhiteForeground" Color="#FF424242" />
    <SolidColorBrush x:Key="NoteDarkForeground" Color="#FFFFFFFF" />

    <!-- ===== Accent & shared brushes ===== -->
    <SolidColorBrush x:Key="NoteAccentBrush" Color="#FF0078D4" />
    <SolidColorBrush x:Key="NoteBorderBrush" Color="#66000000" />
    <SolidColorBrush x:Key="NoteToolbarButtonHoverBrush" Color="#33000000" />
    <SolidColorBrush x:Key="NoteToolbarButtonPressedBrush" Color="#4D000000" />

</ResourceDictionary>